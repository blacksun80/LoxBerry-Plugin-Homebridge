#!/bin/bash
# uninstall
#
# Laeuft als User "root", am Ende einer Deinstallation.
#
# Raeumt nur Dinge auf, die AUSSERHALB des Plugin-Ordners liegen. Config,
# Data (inkl. Runtime) usw. innerhalb des Plugin-Ordners loescht der
# LoxBerry-Installer selbst.
#
# Schritt 1: Homebridge-Dienst stoppen und deinstallieren (systemd-Unit).
# Schritt 2: Backup-Ordner (Config + Runtime) loeschen.
#
# Argumente: command <TEMPFOLDER> <NAME> <FOLDER> <VERSION> <BASEFOLDER>

COMMAND=$0
PTEMPDIR=$1
PSHNAME=$2
PDIR=$3
PVERSION=$4
LBHOMEDIR=$5

PDATA=$LBPDATA/$PDIR
HB_RUNTIME_DIR="$PDATA/homebridge_runtime"
HB_NODE_DIR="$HB_RUNTIME_DIR/nodejs"
HB_NPM_GLOBAL="$HB_RUNTIME_DIR/npm-global"
HB_SERVICE="$HB_NPM_GLOBAL/bin/hb-service"
SERVICE_UNIT="/etc/systemd/system/homebridge.service"

BACKUP_ROOT="$LBHOMEDIR/data/system/tmp/homebridge_backup"

echo "============================================================"
echo "Schritt 1: Homebridge-Dienst deinstallieren"
echo "============================================================"

systemctl stop homebridge.service 2>/dev/null || true

export PATH="$HB_NODE_DIR/bin:$HB_NPM_GLOBAL/bin:$PATH"
if [ -x "$HB_SERVICE" ]; then
    "$HB_SERVICE" uninstall || true
fi

if [ -f "$SERVICE_UNIT" ]; then
    echo "<INFO> Entferne verbliebenes systemd-Unit."
    systemctl disable --now homebridge.service 2>/dev/null || true
    rm -f "$SERVICE_UNIT"
    systemctl daemon-reload 2>/dev/null || true
fi

echo ""
echo "============================================================"
echo "Schritt 2: Backup-Ordner loeschen"
echo "============================================================"

if [ -d "$BACKUP_ROOT" ]; then
    echo "<INFO> Entferne $BACKUP_ROOT."
    rm -rf "$BACKUP_ROOT"
else
    echo "<INFO> Kein Backup-Ordner vorhanden."
fi

echo "<OK> Aufraeumen abgeschlossen."

exit 0
