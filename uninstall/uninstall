#!/bin/bash
#
# Wird als User "root" ausgefuehrt, wenn das Plugin deinstalliert wird.
# Entfernt den Homebridge-systemd-Dienst (mit dem isolierten hb-service),
# raeumt Reste auf und loescht die Config-Backups.
#
# Das isolierte Node.js + Homebridge liegen unter der persistenten Runtime
# ($LBHOMEDIR/data/system/homebridge_runtime) - ausserhalb der Plugin-Ordner,
# daher loescht der LoxBerry-Installer sie NICHT. Dieses Skript raeumt sie
# deshalb selbst weg (kein npm noetig, einfach das Verzeichnis entfernen).
# Das System-Node (apt, /usr/bin/node) bleibt bewusst stehen, da es von
# anderen Komponenten genutzt werden koennte.
#
# Exit code 0 = ok, 1 = Warnung (Deinstallation laeuft weiter).
#
# Argumente: command <TEMPFOLDER> <NAME> <FOLDER> <VERSION> <BASEFOLDER>

COMMAND=$0
PTEMPDIR=$1
PSHNAME=$2
PDIR=$3
PVERSION=$4
LBHOMEDIR=$5

HB_RUNTIME_DIR="$LBHOMEDIR/data/system/homebridge_runtime"
HB_NODE_DIR="$HB_RUNTIME_DIR/nodejs"
HB_NPM_GLOBAL="$HB_RUNTIME_DIR/npm-global"
HB_SERVICE="$HB_NPM_GLOBAL/bin/hb-service"
SERVICE_UNIT="/etc/systemd/system/homebridge.service"

echo "<INFO> Deinstalliere Homebridge-Dienst."

# Dienst stoppen (egal ob Unit-ExecStart noch gueltig ist).
systemctl stop homebridge.service 2>/dev/null || true

# Bevorzugt sauber ueber das isolierte hb-service deinstallieren.
export PATH="$HB_NODE_DIR/bin:$HB_NPM_GLOBAL/bin:$PATH"
if [ -x "$HB_SERVICE" ]; then
    "$HB_SERVICE" uninstall || true
fi

# Hart nachraeumen, falls das systemd-Unit noch existiert.
if [ -f "$SERVICE_UNIT" ]; then
    echo "<INFO> Entferne verbliebenes systemd-Unit."
    systemctl disable --now homebridge.service 2>/dev/null || true
    rm -f "$SERVICE_UNIT"
    systemctl daemon-reload 2>/dev/null || true
fi

# Cleanup-Marker der Fremd-Node-Bereinigung entfernen, damit eine spaetere
# Neuinstallation die Pruefung wieder von vorne durchfuehrt.
rm -f "$LBHOMEDIR/data/system/homebridge_node_cleanup_done"

# Config-Backups entfernen - sonst wuerde eine spaetere Neuinstallation ueber
# postroot.sh eine alte Konfiguration wiederherstellen.
rm -rf "$LBHOMEDIR/data/system/tmp/homebridge_config_backup"

# Persistente Runtime (isoliertes Node.js + Homebridge) entfernen. Sie liegt
# ausserhalb der Plugin-Ordner und wird vom LoxBerry-Installer NICHT geloescht,
# muss also hier explizit weg.
echo "<INFO> Entferne persistente Homebridge-Runtime unter $HB_RUNTIME_DIR."
rm -rf "$HB_RUNTIME_DIR"

echo "<OK> Homebridge-Dienst und Runtime entfernt."

exit 0
